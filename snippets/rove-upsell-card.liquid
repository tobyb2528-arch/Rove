{% comment %}
  Renders one compact product card for the "Complete your day out" cart upsell.
  Image, name and price are pulled live from the product object — never hardcoded.

  Accepts:
  - product: {Object} Shopify product

  Usage:
  {% render 'rove-upsell-card', product: product %}
{% endcomment %}

<div class="rove-upsell-card" data-rove-upsell-product-id="{{ product.id }}">
  <a href="{{ product.url }}" class="rove-upsell-card__media" tabindex="-1" aria-hidden="true">
    {%- if product.featured_image -%}
      <img
        class="rove-upsell-card__image"
        src="{{ product.featured_image | image_url: width: 300 }}"
        srcset="{{ product.featured_image | image_url: width: 200 }} 200w, {{ product.featured_image | image_url: width: 300 }} 300w, {{ product.featured_image | image_url: width: 600 }} 600w"
        sizes="(min-width: 750px) 20vw, 8rem"
        alt="{{ product.featured_image.alt | default: product.title | escape }}"
        width="300"
        height="{{ 300 | divided_by: product.featured_image.aspect_ratio | ceil }}"
        loading="lazy"
      >
    {%- endif -%}
  </a>

  <div class="rove-upsell-card__body">
    <a href="{{ product.url }}" class="rove-upsell-card__name">{{ product.title | escape }}</a>
    <p class="rove-upsell-card__price">{{ product.price | money }}</p>

    {%- assign form_id = 'rove-upsell-form-' | append: product.id -%}
    {%- assign aria_label = 'Add ' | append: product.title | append: ' to cart' -%}
    {%- render 'rove-buy-form', product: product, form_id: form_id, button_label: 'Add', button_aria_label: aria_label -%}
  </div>
</div>
